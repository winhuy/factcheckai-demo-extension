{
  "manifest_version": 3,
  "name": "FactCheckAI - Xác minh tin tức",
  "version": "1.0.0",
  "description": "Xác thực độ đúng đắn của tin tức bằng AI Agent & Graph-RAG giới hạn trong nguồn Whitelist chính thống.",
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon-48.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
